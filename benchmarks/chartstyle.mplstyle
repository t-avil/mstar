# Shared chart style for all benchmarks in this workspace (CLAUDE.md: one style,
# established once, imported by every chart). Deliberate publication-clean style;
# not pixel-extracted from the M* paper PDF (best-effort), so treat exact font/
# color as our own convention, applied consistently across every figure.
figure.figsize: 6.4, 4.0
figure.dpi: 140
savefig.dpi: 200
savefig.bbox: tight

font.family: sans-serif
font.sans-serif: DejaVu Sans
font.size: 11
axes.titlesize: 12
axes.labelsize: 11
xtick.labelsize: 10
ytick.labelsize: 10
legend.fontsize: 10

axes.grid: True
axes.grid.axis: y
grid.color: cccccc
grid.linewidth: 0.6
grid.alpha: 0.7
axes.axisbelow: True
axes.spines.top: False
axes.spines.right: False
axes.edgecolor: 444444
axes.linewidth: 0.9

lines.linewidth: 2.0
lines.markersize: 6
legend.frameon: False
