# =============================================================================
# mminf test configuration — copy this file to .env and edit your values
#   cp test/bagel/.sample.env test/bagel/.env
# =============================================================================

# --- User identity (used for temp paths) ---
WHO=yourname

# --- GPU devices (comma-separated) ---
DEVICES=0,1,2

# --- Server ports ---
PORT=8000
MOONCAKE_PORT=8081

# --- Cache directory for model weights ---
# ptc:       /mnt/storage/$WHO/mminf/bagel/
# coriander: /m-coriander/coriander/$WHO/mminf_cache/bagel/
CACHE_DIR=/mnt/storage/yourname/mminf/bagel/

# --- Tensor transfer protocol ---
# ptc:       RDMA  (faster)
# coriander: TCP   (required)
TENSOR_PROTOCOL=RDMA

# --- TCP loopback device (when running on a single node) ---
TCP_DEVICE=lo

# --- Server host ---
HOST=0.0.0.0

# --- VBench benchmark cache (downloads datasets here) ---
# Must be a directory YOU have write access to
VBENCH_CACHE_DIR=/mnt/storage/yourname/vbench
